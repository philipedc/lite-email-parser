{
  "name": "lite-email-parser",
  "version": "1.0.2",
  "description": "Parse email to get signature, replies, attachments and inline images",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "npx tsc && npx tsc --module commonjs --outDir dist/cjs --declaration && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "start": "node ./dist/index.js",
    "test": "npx -y tsx sample/sample.ts"
  },
  "author": "philipedc",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philipedc/lite-email-parser.git"
  },
  "bugs": {
    "url": "https://github.com/philipedc/lite-email-parser/issues"
  },
  "homepage": "https://github.com/philipedc/lite-email-parser#readme",
  "keywords": [
    "email",
    "parser",
    "email-parser",
    "mailparser",
    "extract-attachments",
    "remove-signature",
    "remove-replies",
    "inline-images",
    "lite-email-parser",
    "email-to-html",
    "signature-remover"
  ],
  "dependencies": {
    "cheerio": "^1.2.0",
    "mailparser": "^3.9.14"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "typescript": "^7.0.2"
  }
}
