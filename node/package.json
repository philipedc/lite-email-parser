{
  "name": "lite-email-parser",
  "version": "1.0.3",
  "description": "Parse email to get signature, replies, attachments and inline images",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "install": "node-gyp rebuild",
    "build": "node-gyp rebuild && npx tsc && npx tsc --module commonjs --outDir dist/cjs --declaration && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "test": "npx -y tsx samples/sample.ts"
  },
  "author": "philipedc",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philipedc/lite-email-parser.git"
  },
  "bugs": {
    "url": "https://github.com/philipedc/lite-email-parser/issues"
  },
  "keywords": [
    "email",
    "parser",
    "email-parser",
    "mailparser",
    "extract-attachments",
    "remove-signature",
    "remove-replies",
    "inline-images",
    "lite-email-parser",
    "email-to-html",
    "signature-remover"
  ],
  "dependencies": {
    "node-addon-api": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "node-gyp": "^10.1.0",
    "typescript": "^7.0.2"
  }
}
