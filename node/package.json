{
  "name": "lite-email-parser",
  "version": "2.0.0",
  "description": "Parse email to get signature, replies, attachments and inline images",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist/"
  ],
  "binary": {
    "module_name": "parser",
    "module_path": "./build/Release/",
    "host": "https://github.com/philipedc/lite-email-parser/releases/download/",
    "remote_path": "{version}",
    "package_name": "{module_name}-v{version}-{node_abi}-{platform}-{arch}.tar.gz"
  },
  "scripts": {
    "install": "prebuild-install",
    "build": "node-gyp rebuild && npx tsc && npx tsc --module commonjs --outDir dist/cjs --declaration && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "test": "npx -y tsx samples/sample.ts",
    "prebuild": "node-gyp rebuild && mkdir -p prebuilds && tar -czf prebuilds/parser-v2.0.0-napi-v9-linux-x64.tar.gz build/Release/parser.node"
  },
  "author": "philipedc",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philipedc/lite-email-parser.git"
  },
  "bugs": {
    "url": "https://github.com/philipedc/lite-email-parser/issues"
  },
  "keywords": [
    "email",
    "parser",
    "email-parser",
    "mailparser",
    "extract-attachments",
    "remove-signature",
    "remove-replies",
    "inline-images",
    "lite-email-parser",
    "email-to-html",
    "signature-remover"
  ],
  "dependencies": {
    "node-addon-api": "^8.0.0",
    "prebuild-install": "^7.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "node-gyp": "^10.1.0",
    "typescript": "^7.0.2"
  }
}
